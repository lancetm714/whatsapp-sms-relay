PORT=3000

# Vonage SMS credentials (leave empty to use stub/dry-run mode)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# Where to relay WhatsApp messages to
SMS_TO_NUMBER=

# Optional: only relay from specific WhatsApp numbers (comma-separated)
# Leave empty to relay all messages
RELAY_WHATSAPP_FROM=
