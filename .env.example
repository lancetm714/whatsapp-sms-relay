PORT=3000

# Textbee SMS gateway credentials (leave empty to use stub/dry-run mode)
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=

# Where to relay WhatsApp messages to
SMS_TO_NUMBER=

# Optional: only relay from specific WhatsApp numbers (comma-separated)
# Leave empty to relay all messages
RELAY_WHATSAPP_FROM=
