PORT=3000

# Vendel SMS gateway credentials (leave empty to use stub/dry-run mode)
VENDEL_API_KEY=
VENDEL_BASE_URL=https://app.vendel.cc

# Where to relay WhatsApp messages to
SMS_TO_NUMBER=

# Optional: only relay from specific WhatsApp numbers (comma-separated)
# Leave empty to relay all messages
RELAY_WHATSAPP_FROM=
