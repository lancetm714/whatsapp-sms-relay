PORT=3000

# SMS Provider — leave one set empty for dry-run mode
# Vendel (recommended — free, uses your own Android phone)
VENDEL_API_KEY=
VENDEL_BASE_URL=https://app.vendel.cc

# Vonage (alternative — requires Vonage account)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# Where to relay WhatsApp messages to
SMS_TO_NUMBER=

# Optional: only relay from specific WhatsApp numbers (comma-separated)
# Leave empty to relay all messages
RELAY_WHATSAPP_FROM=
